# ─────────────────────────────────────────
# NEXUS PLATFORM — Environment Variables
# Copy to .env.local and fill in values
# NEVER commit .env.local to git
# ─────────────────────────────────────────

# ── DATABASE ──────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/nexus_production?schema=public&sslmode=require"

# ── AUTH ──────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_GENERATE_STRONG_SECRET"
NEXTAUTH_URL="https://app.nexusprivatecredit.com"  # investor portal
ADMIN_NEXTAUTH_URL="https://admin.nexusprivatecredit.com"

# JWT signing key for API tokens
JWT_SECRET="CHANGE_ME_GENERATE_STRONG_SECRET"

# ── EMAIL (Postmark / Resend) ─────────────
EMAIL_PROVIDER="resend"            # "resend" | "postmark" | "sendgrid"
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@nexusprivatecredit.com"
EMAIL_FROM_NAME="Nexus Private Credit"

# ── FILE STORAGE (S3-compatible) ──────────
STORAGE_PROVIDER="s3"              # "s3" | "supabase" | "r2"
AWS_REGION="eu-west-2"
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="..."
AWS_S3_BUCKET="nexus-platform-files"
AWS_S3_BUCKET_PUBLIC="nexus-platform-public"
# For Cloudflare R2:
# R2_ACCOUNT_ID="..."
# R2_ACCESS_KEY_ID="..."
# R2_SECRET_ACCESS_KEY="..."
# R2_BUCKET="nexus-files"

# ── SIGNED URL EXPIRY ─────────────────────
SIGNED_URL_EXPIRY_SECONDS="3600"

# ── REDIS (sessions / queues / cache) ─────
REDIS_URL="redis://localhost:6379"
# For Upstash:
# UPSTASH_REDIS_REST_URL="https://..."
# UPSTASH_REDIS_REST_TOKEN="..."

# ── KYC PROVIDER ──────────────────────────
KYC_PROVIDER="sumsub"              # "sumsub" | "onfido" | "manual"
SUMSUB_APP_TOKEN="..."
SUMSUB_SECRET_KEY="..."
SUMSUB_BASE_URL="https://api.sumsub.com"
SUMSUB_WEBHOOK_SECRET="..."

# ── BLOCKCHAIN / CUSTODY ──────────────────
# Fireblocks (production custody)
FIREBLOCKS_API_KEY="..."
FIREBLOCKS_PRIVATE_KEY_PATH="/run/secrets/fireblocks_key.pem"
FIREBLOCKS_BASE_URL="https://api.fireblocks.io"
FIREBLOCKS_ENABLED="false"         # set true when ready

# Polygon RPC (for on-chain settlement logs)
POLYGON_RPC_URL="https://polygon-mainnet.g.alchemy.com/v2/..."

# ── CRYPTO (wallet addresses, read-only) ──
USDC_CONTRACT_POLYGON="0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174"
USDT_CONTRACT_POLYGON="0xc2132D05D31c914a87C6611C10748AEb04B58e8F"

# ── CHAINALYSIS (AML screening) ───────────
CHAINALYSIS_API_KEY="..."
CHAINALYSIS_ENABLED="false"

# ── RATE LIMITING ─────────────────────────
AUTH_RATE_LIMIT_ATTEMPTS="5"
AUTH_RATE_LIMIT_WINDOW_SECONDS="900"  # 15 min lockout

# ── ADMIN ACCESS RESTRICTION ──────────────
ADMIN_ALLOWED_IPS=""               # comma-separated, empty = no IP restriction
ADMIN_DOMAIN="admin.nexusprivatecredit.com"

# ── CRON / BACKGROUND JOBS ────────────────
CRON_SECRET="CHANGE_ME_GENERATE_STRONG_SECRET"
QUEUE_PROVIDER="bullmq"            # "bullmq" | "inngest" | "vercel-cron"

# ── FEATURE FLAGS ─────────────────────────
FEATURE_CRYPTO_DEPOSITS="false"
FEATURE_AUTO_INVEST="true"
FEATURE_CREDIT_LINE="true"
FEATURE_MAGIC_LINK="false"
FEATURE_2FA="true"

# ── MONITORING ────────────────────────────
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ── ANALYTICS ─────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ── APP URLS ──────────────────────────────
NEXT_PUBLIC_INVESTOR_URL="https://app.nexusprivatecredit.com"
NEXT_PUBLIC_ADMIN_URL="https://admin.nexusprivatecredit.com"
