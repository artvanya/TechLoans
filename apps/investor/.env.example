DATABASE_URL=postgresql://USER:PASSWORD@HOST/dbname?sslmode=require

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_SECRET=same-as-or-distinct-from-NEXTAUTH_SECRET

NEXT_PUBLIC_INVESTOR_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Do not set AWS_S3_BUCKET to an empty string when using R2.

# Optional: public read base for deal images (custom R2 domain)
# NEXT_PUBLIC_STORAGE_READ_BASE_URL=https://files.example.com
