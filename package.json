{
  "name": "nexus-platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "cd packages/db && npx prisma generate",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:studio": "cd packages/db && npx prisma studio",
    "db:seed:demo": "cd packages/db && DEMO_SEED=1 pnpm exec tsx prisma/seed-demo.ts"
  },
  "devDependencies": {
    "pnpm": "^9.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}